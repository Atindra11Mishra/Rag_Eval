# LLM generation provider. Groq is the recommended free demo option.
LLM_API_KEY=gsk_...
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=openai/gpt-oss-120b

# NVIDIA NIM alternative:
# LLM_API_KEY=nvapi-...
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# Local/free embeddings. This model is downloaded from Hugging Face on first use.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval
RETRIEVAL_MODE=hybrid
RETRIEVAL_TOP_K=10
FINAL_TOP_K=4

# Reranking
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_TOP_N=4
RERANKER_CANDIDATE_DEPTH=20

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=rag_chunks

# CORS. "*" is intentionally permissive for the current demo deployment.
ALLOWED_ORIGINS=*

# Supabase is optional for local/demo runs.
SUPABASE_URL=
SUPABASE_KEY=
