# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model names (defaults shown)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10        # candidates fetched from vector store
FINAL_TOP_K=4             # chunks sent to generation prompt

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=rag_chunks

# ── Supabase (Phase 7 — leave blank for now) ──────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
